# Copy this file to e2e-tests/tempo-privy-payroll.env and fill the blank values.
# The real .env file is ignored by git.

CHAINROLL_E2E_BASE_URL=http://127.0.0.1:3001
CHAINROLL_E2E_EXECUTE_REAL_PAYOUTS=true

# Leave blank to let the e2e test generate fresh TSIDs.
CHAINROLL_E2E_TENANT_ID=
CHAINROLL_E2E_ACTOR_ID=

# Tempo pathUSD defaults.
CHAINROLL_E2E_TOKEN_SYMBOL=pathUSD
CHAINROLL_E2E_TOKEN_ADDRESS=0x20c0000000000000000000000000000000000000
CHAINROLL_E2E_TOKEN_DECIMALS=18
CHAINROLL_E2E_AMOUNT_UNITS=1

# Required by the API process and by the optional wallet creation helper.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Fill these after creating/funding the Privy treasury wallet.
TEMPO_PRIVY_WALLET_ID=
CHAINROLL_E2E_TREASURY_ADDRESS=

# Employee recipient wallets.
CHAINROLL_E2E_EMPLOYEE_WALLETS=0x8a255735652b2948Db1c4c04D45C00A86afD7C78,0x4B6E954Ed7082248D186e2b213603795E8BF343C,0x88433a95eC7a68DDc81AcbB01053BF80dA031db1
